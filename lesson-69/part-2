<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Закон Кулона: Інтерактивний Тренажер</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://polyfill.io/v3/polyfill.min.js?features=es6"></script>
    <script>
        window.MathJax = {
            tex: {
                inlineMath: [['$', '$'], ['\\(', '\\)']],
                displayMath: [['$$', '$$']]
            },
            chtml: {
                fontURL: 'https://cdn.jsdelivr.net/npm/mathjax@3/es5/output/chtml/fonts/woff-v2'
            },
            svg: { fontCache: 'global' }
        };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <style>
        /* Уніфікація шрифту для всього документа */
        :root {
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .correct { background-color: #d1fae5 !important; border-color: #10b981 !important; color: #065f46; font-weight: bold; }
        .incorrect { background-color: #fee2e2 !important; border-color: #ef4444 !important; color: #991b1b; }
        
        /* Таблиця та заголовки */
        th {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0 !important;
            padding: 0 !important;
        }

        .header-cell {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100px;
            gap: 8px;
        }

        .symbol-text {
            font-size: 1.15rem;
            font-weight: 700;
            color: #1e293b;
        }

        .unit-text {
            color: #64748b;
            font-size: 0.85rem;
            font-weight: 500;
        }

        /* Стилізація випадаючого списку */
        select {
            appearance: none;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236366f1' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: right 0.5rem center;
            background-size: 1em;
            padding-right: 2rem;
            font-family: inherit;
        }

        /* Анімація помилки */
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-4px); }
            75% { transform: translateX(4px); }
        }
        .animate-shake { animation: shake 0.2s ease-in-out 0s 2; }
    </style>
</head>
<body class="bg-slate-50 min-h-screen p-4 md:p-8">

    <div class="max-w-6xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden border border-slate-200">
        <!-- Заголовок -->
        <div class="bg-indigo-600 p-8 text-white text-center">
            <h1 class="text-3xl font-extrabold mb-3 tracking-tight">Закон Кулона</h1>
            <p class="text-indigo-100 opacity-90 font-medium">Оберіть правильне значення для кожної величини</p>
            
            <div class="flex flex-wrap justify-center gap-6 mt-6">
                <div class="bg-white/10 backdrop-blur-md px-6 py-4 rounded-2xl border border-white/20">
                    <div class="text-2xl font-light">$F = k \frac{|q_1| \cdot |q_2|}{r^2}$</div>
                </div>
                <div class="bg-white/5 backdrop-blur-sm px-6 py-4 rounded-2xl border border-white/10 flex items-center gap-6 text-indigo-100">
                    <div class="text-lg">$a^x \cdot a^y = a^{x+y}$</div>
                    <div class="w-px h-6 bg-white/20"></div>
                    <div class="text-lg">$\frac{a^x}{a^y} = a^{x-y}$</div>
                </div>
            </div>
        </div>

        <div class="p-6 md:p-10">
            <!-- Інфо-панель -->
            <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-6 bg-indigo-50/50 p-6 rounded-2xl border border-indigo-100">
                <div class="flex items-center gap-4">
                    <div class="bg-white p-3 rounded-xl shadow-sm border border-indigo-100">
                        <span class="text-indigo-600 font-bold text-lg">$k = 9 \cdot 10^9$</span>
                        <span class="text-slate-500 text-sm ml-1">$\frac{\text{Н} \cdot \text{м}^2}{\text{Кл}^2}$</span>
                    </div>
                </div>
                <button onclick="generateNewTasks()" class="w-full md:w-auto bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-12 rounded-xl transition-all shadow-md hover:shadow-indigo-200 active:scale-95">
                    Нові завдання
                </button>
            </div>

            <!-- Таблиця -->
            <div class="overflow-x-auto rounded-2xl border border-slate-200 shadow-sm">
                <table class="w-full text-center border-collapse">
                    <thead>
                        <tr class="divide-x divide-slate-200">
                            <th class="w-1/6">
                                <div class="header-cell">
                                    <span class="symbol-text">k</span>
                                    <span class="unit-text">$\frac{\text{Н} \cdot \text{м}^2}{\text{Кл}^2}$</span>
                                </div>
                            </th>
                            <th class="w-1/6">
                                <div class="header-cell">
                                    <span class="symbol-text">|q₁|</span>
                                    <span class="unit-text">Кл</span>
                                </div>
                            </th>
                            <th class="w-1/6">
                                <div class="header-cell">
                                    <span class="symbol-text">|q₂|</span>
                                    <span class="unit-text">Кл</span>
                                </div>
                            </th>
                            <th class="w-1/6">
                                <div class="header-cell">
                                    <span class="symbol-text">r</span>
                                    <span class="unit-text">м</span>
                                </div>
                            </th>
                            <th class="w-1/6">
                                <div class="header-cell">
                                    <span class="symbol-text">F</span>
                                    <span class="unit-text">Н</span>
                                </div>
                            </th>
                            <th class="w-1/6 bg-slate-100/50">
                                <div class="header-cell">
                                    <span class="text-[10px] font-black tracking-[0.2em] text-slate-400 uppercase">Результат</span>
                                    <span class="text-xs font-bold text-slate-500">СТАТУС</span>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody id="exerciseTableBody" class="divide-y divide-slate-100">
                        <!-- Динамічні рядки -->
                    </tbody>
                </table>
            </div>

            <div id="feedback" class="mt-10 p-4 rounded-2xl hidden text-center font-bold text-lg border transition-all"></div>
        </div>
    </div>

    <script>
        const K_VAL = 9e9;
        let tasks = [];
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

        function playSound(type) {
            const oscillator = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            oscillator.connect(gainNode);
            gainNode.connect(audioCtx.destination);
            if (type === 'correct') {
                oscillator.type = 'sine';
                oscillator.frequency.setValueAtTime(880, audioCtx.currentTime);
                gainNode.gain.setValueAtTime(0.05, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.2);
            } else {
                oscillator.type = 'triangle';
                oscillator.frequency.setValueAtTime(150, audioCtx.currentTime);
                gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
                gainNode.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
            }
            oscillator.start();
            oscillator.stop(audioCtx.currentTime + 0.3);
        }

        function formatDisplay(num) {
            if (num === 0) return "0";
            if (num >= 0.01 && num <= 1000) return num.toFixed(2).replace(/\.?0+$/, '');
            const exp = Math.floor(Math.log10(Math.abs(num)));
            const mantissa = num / Math.pow(10, exp);
            const formattedMantissa = mantissa.toFixed(1).replace(/\.?0+$/, '');
            return `${formattedMantissa} \u22C5 10${toSuperscript(exp)}`;
        }

        function toSuperscript(num) {
            const map = {'0':'⁰','1':'¹','2':'²','3':'³','4':'⁴','5':'⁵','6':'⁶','7':'⁷','8':'⁸','9':'⁹','-':'⁻'};
            return String(num).split('').map(c => map[c] || c).join('');
        }

        function generateOptions(correctVal) {
            let options = [correctVal];
            while(options.length < 4) {
                let fake;
                const r = Math.random();
                if (r < 0.33) fake = correctVal * 10;
                else if (r < 0.66) fake = correctVal / 10;
                else fake = correctVal * (0.5 + Math.random());
                if (!options.some(opt => Math.abs(opt - fake) / correctVal < 0.05)) options.push(fake);
            }
            return options.sort(() => Math.random() - 0.5);
        }

        function generateNewTasks() {
            tasks = [];
            const tableBody = document.getElementById('exerciseTableBody');
            tableBody.innerHTML = '';
            const types = ['f', 'f', 'f', 'q1', 'q1', 'q1', 'q2', 'q2', 'q2', 'r', 'r', 'r'];
            types.sort(() => Math.random() - 0.5);

            types.forEach((type, i) => {
                let q1 = (Math.floor(Math.random() * 9) + 1) * 1e-6; 
                let q2 = (Math.floor(Math.random() * 9) + 1) * 1e-6; 
                let r = (Math.floor(Math.random() * 8) + 2) * 0.1;   
                let f = K_VAL * (q1 * q2) / (r * r);
                tasks.push({ k: K_VAL, q1, q2, r, f, hidden: type });
                renderRow(tasks[i], i);
            });
            if (window.MathJax) MathJax.typeset();
        }

        function renderRow(task, index) {
            const row = document.createElement('tr');
            row.className = "divide-x divide-slate-100 hover:bg-slate-50/50 transition-colors";
            
            const createCell = (val, isHidden) => {
                const td = document.createElement('td');
                td.className = "p-5 font-medium text-slate-600";
                if (isHidden) {
                    const select = document.createElement('select');
                    select.className = "w-full p-2.5 border border-slate-200 rounded-xl text-center font-bold text-indigo-600 focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none transition-all cursor-pointer bg-white shadow-sm";
                    select.id = `select-${index}`;
                    const p = document.createElement('option');
                    p.textContent = "—"; p.value = ""; p.disabled = true; p.selected = true;
                    select.appendChild(p);
                    generateOptions(val).forEach(opt => {
                        const o = document.createElement('option');
                        o.value = opt; o.textContent = formatDisplay(opt);
                        select.appendChild(o);
                    });
                    select.onchange = () => checkTask(index);
                    td.appendChild(select);
                } else {
                    td.innerHTML = formatScientificForCell(val);
                }
                return td;
            };

            row.appendChild(createCell(task.k, false));
            row.appendChild(createCell(task.q1, task.hidden === 'q1'));
            row.appendChild(createCell(task.q2, task.hidden === 'q2'));
            row.appendChild(createCell(task.r, task.hidden === 'r'));
            row.appendChild(createCell(task.f, task.hidden === 'f'));

            const statusTd = document.createElement('td');
            statusTd.className = "p-5 bg-slate-50/30 font-bold text-xs text-slate-300 tracking-wider";
            statusTd.id = `status-${index}`;
            statusTd.textContent = "ОЧІКУВАННЯ";
            row.appendChild(statusTd);
            document.getElementById('exerciseTableBody').appendChild(row);
        }

        function formatScientificForCell(num) {
            if (num === 0) return "0";
            if (num >= 0.01 && num <= 1000) return num.toFixed(2).replace(/\.?0+$/, '');
            const exp = Math.floor(Math.log10(Math.abs(num)));
            const mantissa = (num / Math.pow(10, exp)).toFixed(1).replace(/\.?0+$/, '');
            return `$${mantissa} \\cdot 10^{${exp}}$`;
        }

        function checkTask(index) {
            const select = document.getElementById(`select-${index}`);
            const status = document.getElementById(`status-${index}`);
            const userVal = parseFloat(select.value);
            const task = tasks[index];
            const correctVal = task[task.hidden];
            
            if (Math.abs(userVal - correctVal) / correctVal < 0.02) {
                select.className = "w-full p-2.5 border-2 border-emerald-500 bg-emerald-50 text-emerald-700 rounded-xl text-center font-bold cursor-default shadow-sm";
                status.textContent = "ПРАВИЛЬНО";
                status.className = "p-5 bg-emerald-50 text-emerald-600 font-black text-xs";
                playSound('correct');
                select.disabled = true;
            } else {
                select.className = "w-full p-2.5 border-2 border-rose-400 bg-rose-50 text-rose-700 rounded-xl text-center font-bold animate-shake shadow-sm";
                status.textContent = "ПОМИЛКА";
                status.className = "p-5 bg-rose-50 text-rose-500 font-black text-xs";
                playSound('incorrect');
                setTimeout(() => { if (!select.disabled) select.classList.remove('animate-shake'); }, 400);
            }
        }

        window.onload = generateNewTasks;
    </script>
</body>
</html>
